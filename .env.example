# Nous Environment Configuration
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and run the setup script to generate
# cryptographically secure credentials:
#
#   cp .env.example .env
#   bash install/setup.sh
#
# The setup script will replace SECRET_KEY, ADMIN_USERNAME, and
# ADMIN_PASSWORD with unique, randomly generated values and
# print them to your terminal.
# ──────────────────────────────────────────────────────────────

SECRET_KEY=change-me-run-bash-install-setup-sh
ADMIN_USERNAME=change-me-run-bash-install-setup-sh
ADMIN_PASSWORD=change-me-run-bash-install-setup-sh

JWT_EXPIRY_HOURS=24
# Shared secret the engine uses to authenticate as a WebSocket producer.
# Optional: leave blank to derive it automatically from SECRET_KEY.
ENGINE_WS_SECRET=
DATABASE_URL=sqlite:///data/db/nous.db
DATA_DIR=./data
SCRIPTS_DIR=./scripts
WORDLIST_PATH=./data/wordlists/dns_wordlist.txt
RESOLVERS_PATH=./data/resolvers/resolvers.txt
RECON_TIMEOUT=3600
TECH_TIMEOUT=0
CRAWL_TIMEOUT=1200
CRAWL_MAX_PAGES=10
TECH_RATE_LIMIT_DELAY=3
DNS_RATE_LIMIT_DELAY=0
CRAWL_RATE_LIMIT_DELAY=0
BACKEND_PORT=8000
FRONTEND_PORT=3000
